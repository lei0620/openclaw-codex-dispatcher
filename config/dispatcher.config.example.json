{
  "server": {
    "host": "0.0.0.0",
    "port": 4318,
    "publicBaseUrl": "http://openclaw-nas:4318"
  },
  "auth": {
    "dispatcherToken": "change-me-panel-token",
    "agentToken": "change-me-agent-token"
  },
  "projects": [
    {
      "id": "openclaw",
      "name": "OpenClaw Bridge",
      "path": "D:/aixm/openclaw",
      "defaultMode": "codex",
      "allowedModes": ["codex", "dry-run"],
      "notify": true
    },
    {
      "id": "sjnews",
      "name": "Design Hot",
      "path": "D:/aixm/sjnews",
      "defaultMode": "codex",
      "allowedModes": ["codex", "dry-run"],
      "notify": true
    }
  ],
  "projectDiscovery": {
    "enabled": true,
    "roots": ["D:/aixm"],
    "exclude": ["beifen"],
    "defaultMode": "codex",
    "allowedModes": ["codex", "dry-run"],
    "notify": true
  },
  "codex": {
    "command": "node",
    "args": ["D:/aixm/openclaw/node_modules/@openai/codex/bin/codex.js", "exec", "--skip-git-repo-check", "--cd", "{{projectPath}}", "{{prompt}}"],
    "promptStdin": false
  },
  "codexAppServer": {
    "enabled": true,
    "url": "ws://127.0.0.1:18765",
    "startupTimeoutMs": 60000,
    "requestTimeoutMs": 30000,
    "turnTimeoutMs": 120000,
    "supervisorIntervalMs": 5000,
    "heartbeatIntervalMs": 10000,
    "refreshDesktopAfterTurn": false,
    "refreshScriptPath": "scripts/refresh-codex-desktop.ps1",
    "refreshWindowTitlePattern": "Codex|OpenAI",
    "refreshTimeoutMs": 8000
  },
  "desktopInput": {
    "enabled": false,
    "allowUnsafeForegroundRouting": false,
    "scriptPath": "scripts/send-codex-desktop-input.ps1",
    "clickYOffset": 92,
    "windowTitlePattern": "Codex|OpenAI",
    "responseTimeoutMs": 180000
  }
}
